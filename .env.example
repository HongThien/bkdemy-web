# Copy thành .env.local, điền giá trị thật khi có (xem BKDEMY_WEB_SPEC.md §3/§7).
NEXT_PUBLIC_SITE_URL=https://bkacademy.edu.vn

# true = luôn dùng seed JSON mock (content/_mock) thay vì gọi bkdemy-ph.
# Để trống/false khi đã có 2 biến Supabase dưới đây — lib/data.ts tự dùng live.
NEXT_PUBLIC_USE_MOCK=false

# Project Supabase bkdemy-ph (anon, CHỈ đọc 2 view công khai) — KHÔNG PHẢI Supabase ERP.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

NEXT_PUBLIC_PH_PORTAL_URL=https://ph.bkacademy.edu.vn
NEXT_PUBLIC_HOC_URL=https://hoc.bkacademy.edu.vn
NEXT_PUBLIC_ZALO_URL=
NEXT_PUBLIC_HOTLINE=
